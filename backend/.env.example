# Backend
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/cyber_threat_db
JWT_SECRET=change_this_secret_in_production
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=verified-sender@example.com
BREVO_SENDER_NAME=CyberShield
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_user
SMTP_PASS=your_brevo_smtp_password
NOTIFICATION_FROM_EMAIL=verified-sender@example.com

# ML Service (Flask)
ML_API_URL=http://127.0.0.1:8000/predict
ML_TIMEOUT_MS=3000

# Python ML Engine
PYTHON_PATH=python
# ML_ENGINE_DIR=../ml_engine (optional override)
